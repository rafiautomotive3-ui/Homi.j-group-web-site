{
  "entities": {
    "Job": {
      "title": "Job Opening",
      "description": "A job opening at Homi.J Global",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The job title" },
        "country": { "type": "string", "description": "The country where the job is located" },
        "description": { "type": "string", "description": "The job description" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the job was created" },
        "status": { "type": "string", "enum": ["open", "closed"], "description": "The status of the job opening" }
      },
      "required": ["title", "country", "description", "createdAt", "status"]
    },
    "Application": {
      "title": "Job Application",
      "description": "A job application from a candidate",
      "type": "object",
      "properties": {
        "jobId": { "type": "string", "description": "The ID of the job being applied for" },
        "jobTitle": { "type": "string", "description": "The title of the job being applied for" },
        "candidateName": { "type": "string", "description": "The name of the candidate" },
        "email": { "type": "string", "format": "email", "description": "The email of the candidate" },
        "education": { "type": "string", "description": "The candidate's educational qualification" },
        "experience": { "type": "string", "description": "The candidate's years of experience" },
        "resumeUrl": { "type": "string", "description": "The URL of the candidate's resume PDF" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The time the application was submitted" }
      },
      "required": ["jobId", "jobTitle", "candidateName", "email", "education", "experience", "resumeUrl", "createdAt"]
    },
    "Livestock": {
      "title": "Livestock",
      "description": "An animal in the dairy management system",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name or ID of the animal" },
        "type": { "type": "string", "enum": ["cow", "buffalo", "sheep"], "description": "The type of animal" },
        "breed": { "type": "string", "description": "The breed of the animal" },
        "purchasePrice": { "type": "number", "description": "Price at which the animal was purchased" },
        "purchaseDate": { "type": "string", "format": "date-time", "description": "Date of purchase" },
        "sellingPrice": { "type": "number", "description": "Price at which the animal was sold" },
        "sellingDate": { "type": "string", "format": "date-time", "description": "Date of sale" },
        "insuranceNumber": { "type": "string", "description": "Insurance policy number" },
        "barcode": { "type": "string", "description": "Barcode or identification code" },
        "imageUrl": { "type": "string", "description": "URL of the animal's image" },
        "status": { "type": "string", "enum": ["active", "sold", "deceased"], "description": "Current status of the animal" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Record creation time" }
      },
      "required": ["name", "type", "breed", "purchasePrice", "purchaseDate", "status", "createdAt"]
    },
    "HealthRecord": {
      "title": "Health Record",
      "description": "A health-related event for an animal",
      "type": "object",
      "properties": {
        "animalId": { "type": "string", "description": "The ID of the animal" },
        "type": { "type": "string", "enum": ["vaccination", "deworming", "checkup", "treatment"], "description": "Type of health event" },
        "description": { "type": "string", "description": "Details of the health event" },
        "date": { "type": "string", "format": "date-time", "description": "Date of the event" },
        "temperature": { "type": "number", "description": "Temperature of the animal" },
        "weight": { "type": "number", "description": "Weight of the animal" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Record creation time" }
      },
      "required": ["animalId", "type", "date", "createdAt"]
    },
    "MilkRecord": {
      "title": "Milk Record",
      "description": "Milk production record for an animal",
      "type": "object",
      "properties": {
        "animalId": { "type": "string", "description": "The ID of the animal" },
        "date": { "type": "string", "format": "date-time", "description": "Date of production" },
        "quantity": { "type": "number", "description": "Quantity in liters" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Record creation time" }
      },
      "required": ["animalId", "date", "quantity", "createdAt"]
    }
  },
  "firestore": {
    "/jobs/{jobId}": {
      "schema": "Job",
      "description": "Collection of job openings"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Collection of job applications"
    },
    "/livestock/{animalId}": {
      "schema": "Livestock",
      "description": "Collection of animals"
    },
    "/livestock/{animalId}/health/{recordId}": {
      "schema": "HealthRecord",
      "description": "Sub-collection of health records"
    },
    "/livestock/{animalId}/milk/{recordId}": {
      "schema": "MilkRecord",
      "description": "Sub-collection of milk records"
    }
  }
}
